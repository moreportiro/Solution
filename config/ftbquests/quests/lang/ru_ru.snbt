	quest.1AAD5F66916A3B00.quest_desc: [
		"    В &5Посох из кармота&r можно вставить блок и получить определённый эффект."
		""
		"    Железо - отбрасывает противников вверх, делая посох сильнее."
		""
		"    Золото - удача I на 2 минуты."
		""
		"    Медь - призывает молнию на себя."
		""
		"    Алмаз - увеличивает урон."
		""
		"    Бронза - призывает молнию на цель."
		""
		"    Незерит - сильнее увеличивает урон, чем Алмаз."
		""
		"    Металлург - сильнее увеличивает урон, чем Незерит, но уменьшает скорость атаки."
		""
		"    Кармот - восстанавливает своё здоровье и здоровье окружающих на 10 единиц."
		"{@pagebreak}"
		"    Злата Мидаса - удача II на 4 минуты."
		""
		"    Рунит - замораживает цель."
		""
		"    Звёздная платина - увеличивает скорость атаки."
		""
		"    Маяк - в радиусе 18 блоков выдает случайный эффект маяка на 30 секунд."
		""
		"    Лазурит - увеличивает получаемый опыт."
		""
		"    Штормикс - при удержании создаёт силовое поле, отражающее снаряды."
		""
		"    Губка - убирает воду в радиусе 12 блоков."
		""
		"    Священный сплав - увеличивает урон."
	]
