	quest.3C264097C15ACF73.title: "&bФолиант мороза&r"
	quest.3C2AAD984DE72095.quest_desc: [
		"    Незеритовое мини-чудище новый &#B48EADдружелюбный компаньон&r."
		""
		"    В Незеритовое мини-чудище можно &#B48EADположить предметы&r, вместительность &#B48EAD15 слотов&r."
		""
		"    После убийства, выпадет предмет призыва и если у компаньона были предметы - тоже выпадут. Восстановить здоровье можно с помощью &#B48EADугля&r."
		""
		"    Для удобного перемещения компаньона, можно &#B48EADвзять ведром&r."
	]
	quest.3C2AAD984DE72095.quest_subtitle: "Приручите &#B48EADНезеритовое мини-чудище&r"
