	quest.21F1417CB09D3970.quest_desc: [
		"    The &#B48EADWaystones&r mod adds a new &#B48EADtravel system&r using waystones and scrolls."
		""
		"• &#B48EADWaystone&r - teleports you to any other &#B48EADactivated Waystone&r."
		""
		"• &#B48EADSharestone&r - teleports you to another &#B48EADSharestone&r of the same &#B48EADcolor&r."
		""
		"• &#B48EADPortstone&r - one-way teleport to a &#B48EADSharestone&r of the same &#B48EADcolor&r."
		""
		"• &#B48EADWarp Plate&r - links to another &#B48EADWarp Plate&r using a Tuned Shard. Can &#B48EADtransport items&r and &#B48EADentities&r between the two &#B48EADlinked plates&r."
		""
		"• &#B48EADWarp Stone&r - teleports you to any &#B48EADactivated Waystone&r from anywhere. Uses item durability."
		""
		"• &#B48EADReturn Scroll&r - teleports you to the &#B48EADclosest activated Waystone&r from anywhere. Single-use."
		""
		"• &#B48EADBlank Scroll&r - used to &#B48EADbind to a Waystone&r, allowing teleportation to it from anywhere. Single-use."
		""
		"• &#B48EADWarp Scroll&r - teleports you to &#B48EADany activated Waystone&r from anywhere. Single-use."
	]
	quest.21F1417CB09D3970.quest_subtitle: "&#B48EADWaystones&r Mod"
	quest.21F1417CB09D3970.title: "&#B48EADWaystones&r"
