	quest.6EB654032C00D32C.quest_desc: [
		"    The Runic Tablet is used to create &#B48EADRunic Weapons&r."
		""
		"    There is a chance to get an enhanced skill, indicated by &#B48EADLarge&r above the skill."
		""
		"    Runic Weapons are created with a unique random skill:"
		""
		"• &#B48EADActive Defense&r shoots arrows if you have any."
		""
		"• &#B48EADLevitation&r chance to apply Levitation to the target."
		""
		"• &#B48EADFreezing&r chance to apply Chilling or Freezing effects to the target."
		""
		"• &#B48EADIcing&r shoots snowballs and slows the target."
		""
		"• &#B48EADInspiration&r chance to deal additional magic damage."
		""
		"• &#B48EADSacrifice&r constant self-damage and ignites nearby enemies."
		""
		"• &#B48EADInstant&r increases forward movement speed."
		""
		"• &#B48EADThorns&r extra damage for each arrow stuck in the target's body."
		"{@pagebreak}"
		"• &#B48EADShielding&r when attacking a target, chance to absorb damage."
		""
		"• &#B48EADSluggishness&r when attacking a target, slows the target."
		""
		"• &#B48EADStone Skin&r when attacking a target, chance to increase defense, but decreases movement speed."
		""
		"• &#B48EADSwiftness&r when attacking a target, chance to increase movement speed."
		""
		"• &#B48EADTrailblazer&r when attacking a target, chance to gain Fire Resistance, increase movement speed, and set self on fire."
		""
		"• &#B48EADInstability&r applies random effects."
		""
		"• &#B48EADWard&r creates an absorption shield by consuming half of current health."
		""
		"• &#B48EADWeakening&r when attacking a target, chance to slow and weaken the target."
		""
		"• &#B48EADIgnition&r when attacking a target, chance to ignite the target and nearby similar targets."
		""
		"• &#B48EADMobility&r when attacking a target, chance to increase movement and attack speed."
		""
		"• &#B48EADThrowing&r throws the weapon and it returns."
	]
	quest.6EB654032C00D32C.quest_subtitle: "Find the Runic Tablet"
