	quest.580FF846269FAF53.quest_desc: [
		"    The Spellblades and Such mod adds enchanted blades, claymores, orbs, and its own mini-progression system based on defeating a faction of mobs and their boss."
		""
		"    Also many armor enchantments:"
		""
		"    &nAbsorbing V&r - Part of the damage absorbed by armor is restored as yellow hearts up to the maximum absorption."
		""
		"    &nDefiance V&r - Mitigates incoming damage."
		""
		"    &nEnduring V&r - Reduces damage taken beyond the endurance threshold. Endurance threshold is a minimum of 20% of max health. Incompatible with Absorbing V, Defiance V."
		""
		"    &nFortified V&r - Increases the endurance threshold, minimum damage reduction 25%. Incompatible with Absorbing V, Defiance V."
		"{@pagebreak}"
		"    &nEvasion V&r - Incoming damage will be glancing, dealing only 65%. Incompatible with the above enchantments."
		""
		"    &nBattle Rouse V&r - Part of the damage taken restores health over 4 seconds. Incompatible with the above enchantments."
		""
		"    &nSpellbreaking V&r - Chance to avoid incoming magic damage, max 75%. Incompatible with the above enchantments."
		""
		"    &nSuppressing V&r - Chance to suppress incoming magic damage by half. Incompatible with the above enchantments."
		""
		"    &nWarding V&r - Recharges yellow hearts. Incompatible with the above enchantments."
		""
		"    &4Curse of Dissolution&r - Reduces max health while taking damage."
		""
		"    &4Curse of the Ethereal&r - -95% max health, but +5 and +100% damage absorption."
	]
	quest.580FF846269FAF53.quest_subtitle: "Spellblades and Such Mod"
