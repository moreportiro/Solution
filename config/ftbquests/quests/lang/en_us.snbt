	quest.0F6AC99C5C076E2C.quest_desc: [
		"    &nFor Mantles:&r"
		""
		"• &#B48EADMagic Protection IV&r - protects against &#B48EADhostile magic&r. Incompatible with &#B48EADProtection IV&r and similar."
		""
		"• &#B48EADTyphoon V&r - boosts &#77CCFFAir&r and &#74DFBFWater&r spell damage. Only for &#77CCFFAir&r and &#74DFBFWater&r mantles."
		""
		"• &#B48EADStonebloom V&r - boosts &#8B4513Earth&r spell damage. Only for &#8B4513Earth&r mantle."
		""
		"• &#B48EADSolar Fire V&r - boosts &5Arcane&r and &4Fire&r spell damage. Only for &5Mystic&r and &4Fire&r mantles."
		""
		"• &#B48EADEnergy Infusion V&r - boosts &eHealing&r damage. Only for &ePriest&r garb and &#EBCB8BPaladin&r armor."
		""
		"• &#B48EADIcy Soul V&r - boosts &bFrost&r spell damage. Only for &bFrost&r mantle."
		"{@pagebreak}"
		"    &nFor Weapons:&r"
		""
		"• &#B48EADInfinite Spells&r - spells &#B48EADdon't consume&r runes."
		""
		"• &#B48EADSpell Power V&r - boosts &#B48EADall spell damage&r."
		""
		"• &#B48EADSpell Speed V&r - increases &#B48EADcasting speed&r. Only for staves/wands/fists."
		""
		"• &#B48EADSpell Amplifier V&r - increases &#B48EADspell crit damage&r. Only for staves/wands/fists."
		""
		"• &#B48EADSpell Critical V&r - increases &#B48EADspell crit chance&r. Only for staves/wands."
	]
