	quest.1A3236B0858AA6F4.quest_desc: [
		"    &#B48EADEnchanting&r is essential for &#B48EADupgrading&r tools and armor."
		""
		"    Enchanted books can be bought from &#B48EADLibrarian villagers&r/found in &#B48EADvarious structures&r/enchanted at &#B48EADenchanting table&r."
		""
		"    Use &#B48EADanvil to enchant&r tools or armor with existing enchanted books."
		"{@pagebreak}"
		"    &#B48EADArmor Enchantments&r"
		""
		"    Armor has &#B48EAD4 main enchantments&r incompatible with each other, plus slot-specific enchantments."
		""
		"    &#B48EADProtection Factor&r - damage reduction (max 20 points). 1 point = 4%, &#B48EADmax 80%&r damage reduction."
		"{@pagebreak}"
		"    &#B48EADWeapon Enchantments&r"
		""
		"    Swords have &#B48EAD3 main damage types&r that are mutually exclusive."
		""
		"    &#B48EADTool Enchantments&r"
		""
		"    Unbreaking and Mending are &#B48EADessential&r for everything."
	]
