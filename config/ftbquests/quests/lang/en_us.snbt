	quest.006DE5C32C5624B4.quest_desc: [
		"    Can &#B48EADcook&r and &#B48EADstore&r large amounts of food."
		""
		"    To cook, the Cooking Pot must be &#B48EADheated&r by a block below it."
		""
		"    &#B48EADHeat sources&r:"
		"• Fire and Soul Fire."
		"• Lava."
		"• Magma Block."
		"• Campfire and Soul Campfire."
		"• Furnace."
		""
		"    &#B48EADHoppers&r and similar blocks from other mods can &#B48EADtransfer items&r through the Cooking Pot:"
		""
		"• &#B48EADTop&r - add ingredients."
		"• &#B48EADSides&r - supply containers."
		"• &#B48EADBottom&r - extract finished meals (heat source can pass through a hopper)."
		""
		"    The Cooking Pot &#B48EADstores 64 servings&r; meals are &#B48EADpreserved&r when broken, but not ingredients/containers."
	]
	quest.006DE5C32C5624B4.quest_subtitle: "Craft a &#B48EADCooking Pot&r and place it above a &#B48EADCampfire&r"
